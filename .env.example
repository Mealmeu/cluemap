ENVIRONMENT=development
POSTGRES_DB=cluemap
POSTGRES_USER=cluemap
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+psycopg://cluemap:change-me-postgres-password@postgres:5432/cluemap
ACCESS_TOKEN_SECRET=change-me-access-secret
REFRESH_TOKEN_SECRET=change-me-refresh-secret
FRONTEND_ORIGIN=http://localhost
CORS_ORIGINS_RAW=http://localhost,http://localhost:5173
TRUSTED_HOSTS_RAW=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS_RAW=http://localhost,http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CSRF_COOKIE_SAMESITE=strict
ALLOW_REFRESH_TOKEN_IN_BODY=false
MAX_REQUEST_BODY_BYTES=65536
LLM_PROVIDER=local
LOCAL_LLM_PROFILE_NAME=ClueMap KR Analyzer
LOCAL_LLM_MODEL_REPO=Qwen/Qwen3-4B-Instruct-2507
LOCAL_LLM_MODEL_FILE=cluemap-kr-analyzer-qwen3-4b-q4_k_m.gguf
LOCAL_LLM_DOWNLOAD_REPO=bartowski/Qwen_Qwen3-4B-Instruct-2507-GGUF
LOCAL_LLM_DOWNLOAD_FILE=Qwen_Qwen3-4B-Instruct-2507-Q4_K_M.gguf
LOCAL_LLM_MODEL_DIR=/models
LOCAL_LLM_AUTO_DOWNLOAD=false
LOCAL_LLM_CHAT_FORMAT=chatml
LOCAL_LLM_N_CTX=2048
LOCAL_LLM_N_THREADS=4
LOCAL_LLM_N_GPU_LAYERS=0
LOCAL_LLM_TEMPERATURE=0.2
LOCAL_LLM_TOP_P=0.9
LOCAL_LLM_TOP_K=40
LOCAL_LLM_REPEAT_PENALTY=1.08
LOCAL_LLM_MAX_TOKENS=384
SANDBOX_MODE=remote
SANDBOX_RUNNER_IMAGE=cluemap-python-runner:latest
SANDBOX_RUNNER_URL=http://runner:9000
SANDBOX_RUNNER_SHARED_SECRET=change-me-runner-secret
SANDBOX_RUNNER_SIGNATURE_TTL_SECONDS=30
SANDBOX_RUNNER_NONCE_CACHE_SECONDS=300
SANDBOX_RUNNER_MAX_REQUEST_BODY_BYTES=65536
SANDBOX_TIMEOUT_SECONDS=3
SANDBOX_MEMORY_LIMIT_MB=128
SANDBOX_OUTPUT_LIMIT_BYTES=16384
SANDBOX_PIDS_LIMIT=64
RUN_SEED_ON_START=false
FORWARDED_ALLOW_IPS=*
VITE_API_BASE_URL=
ENABLE_TLS=false
NGINX_SERVER_NAME=localhost